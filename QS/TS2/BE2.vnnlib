; 4-input vnnlib: intentionally malformed input constraints

(declare-const X_0 Real)
(declare-const X_1 Real)
(declare-const X_2 Real)
(declare-const X_3 Real)

; Looks similar to a normal input box, but the assert form is broken.
(assert (and
  (>= X_0 -1.0) (<= X_0  1.0)
  (>= X_1  0.0) (<= X_1  2.0)
  (>= X_2  0.5) (<= X_2  0.5)
  (>= X_3 -3.0) (<= X_3 -2.0)
)
